# Skip package install scripts. Every dependency here ships prebuilt binaries
# (ffmpeg, ffprobe) or lazy-loads its native pieces (hyperframes' onnxruntime,
# used only by `transcribe`, which this pipeline does not use). Skipping scripts
# avoids a large, network-gated native download and keeps installs reproducible
# on locked-down CI/sandbox networks.
ignore-scripts=true
